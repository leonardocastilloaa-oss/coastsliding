{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "coastsliding",
  "main": "src/worker.js",
  "compatibility_date": "2026-05-12",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": ".",
    "binding": "ASSETS",
    "exclude": [
      "_worker.js",
      "**/_worker.js",
      "src/**",
      ".git/**",
      ".wrangler/**",
      "node_modules/**"
    ]
  }
}
