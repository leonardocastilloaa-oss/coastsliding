<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 800 500" width="800" height="500">
  <defs>
    <linearGradient id="g" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#1B8FD6"/>
      <stop offset="100%" stop-color="#0AADBB"/>
    </linearGradient>
  </defs>
  <rect width="800" height="500" fill="url(#g)"/>
  <rect x="1" y="1" width="798" height="498" fill="none" stroke="rgba(255,255,255,0.2)" stroke-width="2"/>
  <!-- Sliding door icon -->
  <rect x="280" y="80" width="240" height="280" rx="6" fill="none" stroke="rgba(255,255,255,0.5)" stroke-width="3"/>
  <rect x="285" y="85" width="112" height="270" rx="3" fill="rgba(255,255,255,0.15)"/>
  <rect x="403" y="85" width="112" height="270" rx="3" fill="rgba(255,255,255,0.22)"/>
  <rect x="399" y="85" width="4" height="270" fill="rgba(255,255,255,0.5)"/>
  <rect x="482" y="200" width="6" height="40" rx="3" fill="white" opacity="0.8"/>
  <path d="M280 350 Q340 335 400 350 Q460 365 520 350" stroke="rgba(255,255,255,0.5)" stroke-width="2" fill="none"/>
  <!-- Number badge -->
  <circle cx="120" cy="100" r="50" fill="rgba(255,255,255,0.2)"/>
  <text x="120" y="115" text-anchor="middle" font-family="Arial Black, Arial" font-size="48" font-weight="900" fill="white">3</text>
